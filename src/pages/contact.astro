---
import Base from '../layouts/Base.astro';
const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://wickedwick-ebda.vercel.app';
const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'ContactPage',
    name: 'Contact Wicked Wick Co.',
    url: `${siteUrl}/contact`,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
      { '@type': 'ListItem', position: 2, name: 'Contact', item: `${siteUrl}/contact` },
    ],
  },
];
---
<Base
  title="Contact Us | Wicked Wick Co."
  description="Have a question about your order or our candles? Contact Wicked Wick Co. and we'll get back to you within one business day."
  structuredData={structuredData}
>
  <section class="max-w-3xl mx-auto px-5 md:px-8 pt-12 md:pt-16 pb-20">
    <nav class="text-xs text-[#3a322f]/70 mb-4" aria-label="Breadcrumb">
      <a href="/" class="hover:text-[#8a4b2a]">Home</a>
      <span class="mx-2">/</span>
      <span>Contact</span>
    </nav>
    <p class="text-xs uppercase tracking-[0.3em] text-[#8a4b2a] mb-3">Drop us a line</p>
    <h1 class="font-display text-4xl md:text-5xl tracking-tight leading-tight mb-5">Get in touch with Wicked Wick Co.</h1>
    <p class="text-lg text-[#3a322f] leading-relaxed mb-10 max-w-2xl">
      Questions about your order, wholesale, custom candles, or just want to say hi? This is the fastest way to reach us — we reply within one business day.
    </p>

    <div class="grid md:grid-cols-[1fr_320px] gap-8">
      <form id="contact-form" class="rounded-3xl bg-white/80 border border-[#e5d9c5] p-6 md:p-8 space-y-5">
        <div>
          <label for="name" class="block text-sm font-medium mb-1">Your name</label>
          <input id="name" name="name" type="text" required class="w-full rounded-lg border border-[#e5d9c5] bg-white px-4 py-2.5 focus:outline-none focus:border-[#c08457]" />
        </div>
        <div>
          <label for="email" class="block text-sm font-medium mb-1">Email</label>
          <input id="email" name="email" type="email" required class="w-full rounded-lg border border-[#e5d9c5] bg-white px-4 py-2.5 focus:outline-none focus:border-[#c08457]" />
        </div>
        <div>
          <label for="subject" class="block text-sm font-medium mb-1">Subject</label>
          <select id="subject" name="subject" class="w-full rounded-lg border border-[#e5d9c5] bg-white px-4 py-2.5 focus:outline-none focus:border-[#c08457]">
            <option>Order help</option>
            <option>Wholesale inquiry</option>
            <option>Custom candles</option>
            <option>Press &amp; media</option>
            <option>Just saying hi</option>
          </select>
        </div>
        <div>
          <label for="message" class="block text-sm font-medium mb-1">Message</label>
          <textarea id="message" name="message" rows="5" required class="w-full rounded-lg border border-[#e5d9c5] bg-white px-4 py-2.5 focus:outline-none focus:border-[#c08457]"></textarea>
        </div>
        <button type="submit" id="submit-btn" class="rounded-full bg-[#1a1413] text-[#f6efe6] px-6 py-3 font-medium hover:bg-[#8a4b2a] transition disabled:opacity-60">Send message →</button>
        <p id="form-feedback" class="text-sm"></p>
      </form>

      <aside class="space-y-4">
        <div class="rounded-2xl bg-white/70 border border-[#e5d9c5] p-5">
          <h2 class="font-display text-lg mb-2">Before you write</h2>
          <p class="text-sm text-[#3a322f]">Chances are our <a href="/faq" class="underline underline-offset-4 text-[#8a4b2a]">FAQ</a> already has your answer — especially for candle care, burn times, and shipping.</p>
        </div>
        <div class="rounded-2xl bg-white/70 border border-[#e5d9c5] p-5">
          <h2 class="font-display text-lg mb-2">Order issues</h2>
          <p class="text-sm text-[#3a322f]">See our <a href="/shipping-returns" class="underline underline-offset-4 text-[#8a4b2a]">shipping &amp; returns policy</a> for timeline info or to start a return. Or use the form — whichever is faster.</p>
        </div>
        <div class="rounded-2xl bg-[#1a1413] text-[#f6efe6] p-5">
          <h2 class="font-display text-lg mb-2">Still browsing?</h2>
          <p class="text-sm text-[#e5d9c5]/90">No questions, just candles? <a href="/shop" class="underline underline-offset-4 text-[#c08457]">Shop the collection →</a></p>
        </div>
      </aside>
    </div>
  </section>
</Base>
<script is:inline>
  (function() {
    const form = document.getElementById('contact-form');
    const btn = document.getElementById('submit-btn');
    const feedback = document.getElementById('form-feedback');
    if (!form) return;
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      btn.disabled = true; btn.textContent = 'Sending…';
      feedback.className = 'text-sm';
      feedback.textContent = '';
      try {
        const res = await fetch('/api/contact', { method: 'POST', body: new FormData(form) });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Failed');
        feedback.textContent = '✓ Got it. We\'ll be in touch within one business day.';
        feedback.className = 'text-sm text-[#8a4b2a]';
        form.reset();
      } catch (err) {
        feedback.textContent = err.message || 'Something went wrong — please try again.';
        feedback.className = 'text-sm text-red-700';
      } finally {
        btn.disabled = false; btn.textContent = 'Send message →';
      }
    });
  })();
</script>
