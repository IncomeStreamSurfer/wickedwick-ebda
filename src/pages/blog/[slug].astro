---
import Base from '../../layouts/Base.astro';
import { getPostBySlug } from '../../lib/supabase';

export const prerender = false;
const { slug } = Astro.params;
const post = slug ? await getPostBySlug(slug) : null;
const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://wickedwick-ebda.vercel.app';

if (!post) {
  return Astro.redirect('/blog');
}

function renderBody(md: string): string {
  const esc = (s: string) => s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  const lines = md.split(/\n\n+/);
  return lines.map(block => {
    const t = block.trim();
    if (!t) return '';
    if (t.startsWith('## ')) return `<h2 class="font-display text-2xl md:text-3xl mt-8 mb-3">${esc(t.slice(3))}</h2>`;
    if (t.startsWith('# ')) return `<h1 class="font-display text-3xl md:text-4xl mt-8 mb-4">${esc(t.slice(2))}</h1>`;
    if (t.startsWith('- ')) {
      const items = t.split(/\n/).map(l => l.replace(/^- /, '').trim()).filter(Boolean);
      return '<ul class="list-disc ml-6 space-y-1 mb-4">' + items.map(i => `<li>${esc(i)}</li>`).join('') + '</ul>';
    }
    return `<p class="mb-4 leading-relaxed">${esc(t)
      .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
      .replace(/\[(.+?)\]\((.+?)\)/g, '<a href="$2" class="text-[#8a4b2a] underline underline-offset-4">$1</a>')}</p>`;
  }).join('\n');
}

const html = post.body ? renderBody(post.body) : '';

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: post.title,
    datePublished: post.published_at,
    author: { '@type': 'Person', name: post.author ?? 'Wicked Wick Co.' },
    publisher: { '@type': 'Organization', name: 'Wicked Wick Co.', logo: { '@type': 'ImageObject', url: `${siteUrl}/favicon.svg` } },
    image: post.cover_image_url,
    mainEntityOfPage: `${siteUrl}/blog/${post.slug}`,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
      { '@type': 'ListItem', position: 2, name: 'Blog', item: `${siteUrl}/blog` },
      { '@type': 'ListItem', position: 3, name: post.title, item: `${siteUrl}/blog/${post.slug}` },
    ],
  },
];
---
<Base
  title={post.seo_title ?? `${post.title} | Wicked Wick Co.`}
  description={post.seo_description ?? post.excerpt ?? post.title}
  ogImage={post.cover_image_url ?? undefined}
  ogType="article"
  structuredData={structuredData}
>
  <article class="max-w-3xl mx-auto px-5 md:px-8 pt-10 md:pt-14 pb-20">
    <nav class="text-xs text-[#3a322f]/70 mb-4" aria-label="Breadcrumb">
      <a href="/" class="hover:text-[#8a4b2a]">Home</a>
      <span class="mx-2">/</span>
      <a href="/blog" class="hover:text-[#8a4b2a]">Blog</a>
      <span class="mx-2">/</span>
      <span>{post.title}</span>
    </nav>
    {post.tags && post.tags[0] && <p class="text-xs uppercase tracking-[0.3em] text-[#8a4b2a] mb-3">{post.tags[0]}</p>}
    <h1 class="font-display text-4xl md:text-5xl tracking-tight leading-[1.1] mb-4">{post.title}</h1>
    <p class="text-sm text-[#3a322f]/70 mb-8">
      {post.author ?? 'Wicked Wick Co.'} · {post.published_at && new Date(post.published_at).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
    </p>
    {post.cover_image_url && (
      <div class="rounded-3xl overflow-hidden aspect-[16/9] bg-[#e5d9c5] mb-10">
        <img src={post.cover_image_url} alt={post.title} class="w-full h-full object-cover" />
      </div>
    )}
    <div class="text-[#3a322f] text-lg" set:html={html} />
    <hr class="my-12 border-[#e5d9c5]" />
    <div class="rounded-3xl bg-[#1a1413] text-[#f6efe6] p-8 text-center">
      <h2 class="font-display text-2xl tracking-tight mb-3">Ready to light something?</h2>
      <p class="text-[#e5d9c5]/90 mb-5">Browse our six small-batch soy candles.</p>
      <a href="/shop" class="inline-flex items-center gap-2 rounded-full bg-[#c08457] text-[#1a1413] px-6 py-3 font-medium hover:bg-[#f6efe6] transition">Shop candles →</a>
    </div>
  </article>
</Base>
