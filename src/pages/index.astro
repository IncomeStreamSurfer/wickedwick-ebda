---
import Base from '../layouts/Base.astro';
import ProductCard from '../components/ProductCard.astro';
import { getAllProducts, getFeaturedProducts, formatPrice } from '../lib/supabase';

const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://wickedwick-ebda.vercel.app';
const [all, featured] = await Promise.all([getAllProducts(), getFeaturedProducts()]);
const heroProducts = (featured.length ? featured : all).slice(0, 3);

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'Wicked Wick Co.',
    url: siteUrl,
    logo: `${siteUrl}/favicon.svg`,
    description: 'Small-batch, hand-poured soy candles made in a boutique workshop.',
    sameAs: [],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Wicked Wick Co.',
    url: siteUrl,
    description: 'Hand-poured candles for every mood.',
  },
];
---
<Base
  title="Hand-Poured Candles | Wicked Wick Co."
  description="Shop Wicked Wick Co. for small-batch, hand-poured soy candles in unique scents. Perfect for gifts or self-care. Free shipping on orders over $50."
  structuredData={structuredData}
>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-[#f6efe6] via-[#ede0c8] to-[#e5d0b4]" aria-hidden="true"></div>
    <div class="relative max-w-6xl mx-auto px-5 md:px-8 pt-16 md:pt-24 pb-20 md:pb-28 grid md:grid-cols-2 gap-12 items-center">
      <div>
        <p class="text-xs uppercase tracking-[0.3em] text-[#8a4b2a] mb-4">Small-batch · Hand-poured · Clean soy wax</p>
        <h1 class="font-display text-5xl md:text-6xl leading-[1.05] tracking-tight mb-6">
          Artisan hand-poured candles<br />you'll actually obsess over.
        </h1>
        <p class="text-lg text-[#3a322f] max-w-md mb-8 leading-relaxed">
          Six small-batch scents, hand-poured in our workshop into heavyweight vessels. Made for gifting, self-care, and the moments in between.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href="/shop" class="inline-flex items-center gap-2 rounded-full bg-[#1a1413] text-[#f6efe6] px-6 py-3 font-medium hover:bg-[#8a4b2a] transition">
            Shop all candles <span aria-hidden="true">→</span>
          </a>
          <a href="/about" class="inline-flex items-center gap-2 rounded-full border border-[#1a1413]/30 px-6 py-3 font-medium hover:bg-[#1a1413] hover:text-[#f6efe6] transition">
            Our story
          </a>
        </div>
        <div class="mt-10 flex gap-8 text-sm text-[#3a322f]">
          <div><strong class="block font-display text-2xl text-[#1a1413]">100%</strong> soy wax</div>
          <div><strong class="block font-display text-2xl text-[#1a1413]">50+</strong> hr burn time</div>
          <div><strong class="block font-display text-2xl text-[#1a1413]">$50</strong> free ship</div>
        </div>
      </div>
      <div class="relative">
        <div class="grid grid-cols-2 gap-4">
          {heroProducts.slice(0, 2).map((p, i) => (
            <a href={`/shop/${p.slug}`} class={`block rounded-3xl overflow-hidden bg-white/60 border border-[#c08457]/20 shadow-xl ${i === 0 ? 'aspect-[3/4] mt-6' : 'aspect-[3/4]'}`}>
              {p.image_url && <img src={p.image_url} alt={p.image_alt ?? p.name} class="w-full h-full object-cover" />}
            </a>
          ))}
        </div>
        <div class="absolute -bottom-4 -left-4 md:-left-8 bg-[#1a1413] text-[#f6efe6] rounded-2xl px-5 py-4 shadow-2xl max-w-[220px]">
          <p class="text-xs uppercase tracking-widest text-[#c08457] mb-1">Bestseller</p>
          <p class="font-display text-lg leading-tight">{heroProducts[0]?.name ?? 'Amber & Vanilla'}</p>
          <p class="text-xs text-[#e5d9c5]/80 mt-1">{heroProducts[0] ? formatPrice(heroProducts[0].price_pence, heroProducts[0].currency) : ''}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why us strip -->
  <section class="max-w-6xl mx-auto px-5 md:px-8 -mt-6 mb-20">
    <div class="grid sm:grid-cols-3 gap-4 md:gap-6">
      {[
        { icon: '🌿', title: 'Clean soy wax', copy: 'We pour 100% American-grown soy, never paraffin. Cleaner burn, longer life.' },
        { icon: '🕯️', title: 'Hand-poured', copy: 'Every candle is poured, labeled, and boxed by a real human in our studio.' },
        { icon: '🎁', title: 'Ready to gift', copy: 'Heavyweight vessels and matte-black packaging make every order feel like a present.' },
      ].map(c => (
        <div class="rounded-2xl bg-white/70 border border-[#e5d9c5] p-5">
          <div class="text-2xl mb-2" aria-hidden="true">{c.icon}</div>
          <h3 class="font-display text-lg mb-1">{c.title}</h3>
          <p class="text-sm text-[#3a322f]">{c.copy}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- New Arrival — Black Luxury -->
  <section class="bg-[#1a1413]">
    <div class="max-w-6xl mx-auto px-5 md:px-8 py-16 md:py-20 grid md:grid-cols-2 gap-12 items-center">
      <div>
        <p class="text-xs uppercase tracking-[0.3em] text-[#c08457] mb-3">New Arrival</p>
        <h2 class="font-display text-4xl md:text-5xl text-[#f6efe6] tracking-tight mb-4">Black Luxury</h2>
        <div class="mb-4">
          <span class="rounded-full border border-[#c08457]/40 px-3 py-1 text-sm text-[#e5d9c5] inline-block mr-2 mb-2">Dark Resin</span>
          <span class="rounded-full border border-[#c08457]/40 px-3 py-1 text-sm text-[#e5d9c5] inline-block mr-2 mb-2">Smoked Black Pepper</span>
          <span class="rounded-full border border-[#c08457]/40 px-3 py-1 text-sm text-[#e5d9c5] inline-block mr-2 mb-2">Velvety Musk</span>
        </div>
        <p class="text-[#e5d9c5]/80 text-lg leading-relaxed mb-4">
          An opulent blend of dark resins, smoked black pepper and velvety musk. Our most indulgent pour — made for the moments that deserve ceremony.
        </p>
        <p class="text-sm text-[#e5d9c5]/60 mb-8">
          <strong class="text-[#f6efe6] font-medium">55 hrs</strong> burn · <strong class="text-[#f6efe6] font-medium">10 oz</strong> · <strong class="text-[#f6efe6] font-medium">100%</strong> soy
        </p>
        <div class="flex flex-wrap gap-3">
          <a href="/shop/black-luxury" class="rounded-full bg-[#c08457] text-[#1a1413] px-6 py-3 font-medium hover:bg-[#f6efe6] transition">Shop Black Luxury →</a>
          <a href="/collections/luxury-candles" class="rounded-full border border-[#f6efe6]/30 text-[#f6efe6] px-6 py-3 font-medium hover:bg-[#f6efe6]/10 transition">Luxury Candles Collection →</a>
        </div>
      </div>
      <div class="rounded-3xl overflow-hidden aspect-[4/5] max-w-sm ml-auto">
        <img src="https://images.unsplash.com/photo-1643843684801-c61f8e4ab07f?auto=format&fit=crop&w=1200&q=80" alt="Black Luxury candle" class="w-full h-full object-cover" />
      </div>
    </div>
  </section>

  <!-- Featured products -->
  <section class="max-w-6xl mx-auto px-5 md:px-8 mb-20">
    <div class="flex items-end justify-between mb-8">
      <div>
        <p class="text-xs uppercase tracking-[0.3em] text-[#8a4b2a] mb-2">The collection</p>
        <h2 class="font-display text-3xl md:text-4xl tracking-tight">Six candles. Zero filler.</h2>
      </div>
      <a href="/shop" class="hidden md:inline-block text-sm underline underline-offset-4 hover:text-[#8a4b2a]">Browse all →</a>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">
      {all.slice(0, 6).map(p => <ProductCard product={p} />)}
    </div>
  </section>

  <!-- Story -->
  <section class="bg-[#1a1413] text-[#f6efe6] py-20 md:py-24">
    <div class="max-w-4xl mx-auto px-5 md:px-8 text-center">
      <p class="text-xs uppercase tracking-[0.3em] text-[#c08457] mb-4">Made by a human, not a machine</p>
      <h2 class="font-display text-3xl md:text-5xl tracking-tight mb-6">The soy, the scent, and the small studio behind every wick.</h2>
      <p class="text-lg text-[#e5d9c5]/90 leading-relaxed mb-8 max-w-2xl mx-auto">
        Wicked Wick Co. started in a home kitchen with one saucepan, a thermometer, and a stubborn belief that candles should smell like something real — not like "fresh linen" sprayed from a can. Four years in, we still pour every single candle by hand.
      </p>
      <a href="/about" class="inline-flex items-center gap-2 rounded-full bg-[#c08457] text-[#1a1413] px-6 py-3 font-medium hover:bg-[#f6efe6] transition">
        Read our story →
      </a>
    </div>
  </section>

  <!-- Closing CTA -->
  <section class="max-w-6xl mx-auto px-5 md:px-8 py-20 md:py-24 text-center">
    <h2 class="font-display text-3xl md:text-4xl tracking-tight mb-4">Still deciding? We get it.</h2>
    <p class="text-[#3a322f] max-w-xl mx-auto mb-8">
      Every candle ships free over $50 and comes with a 30-day burn guarantee. If it doesn't smell exactly like it says it does, we'll make it right.
    </p>
    <div class="flex flex-wrap justify-center gap-3">
      <a href="/shop" class="inline-flex items-center gap-2 rounded-full bg-[#1a1413] text-[#f6efe6] px-6 py-3 font-medium hover:bg-[#8a4b2a] transition">Shop candles →</a>
      <a href="/faq" class="inline-flex items-center gap-2 rounded-full border border-[#1a1413]/30 px-6 py-3 font-medium hover:bg-[#1a1413] hover:text-[#f6efe6] transition">Read the FAQ</a>
      <a href="/contact" class="inline-flex items-center gap-2 rounded-full border border-[#1a1413]/30 px-6 py-3 font-medium hover:bg-[#1a1413] hover:text-[#f6efe6] transition">Ask us anything</a>
    </div>
  </section>
</Base>
