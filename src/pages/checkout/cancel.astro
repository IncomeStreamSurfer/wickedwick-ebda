---
import Base from '../../layouts/Base.astro';
const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://wickedwick-ebda.vercel.app';
const structuredData = [{
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Checkout Cancelled', item: `${siteUrl}/checkout/cancel` },
  ],
}];
---
<Base
  title="Checkout Cancelled | Wicked Wick Co."
  description="Looks like you cancelled checkout. Your cart is saved — head back and complete your Wicked Wick Co. candle order whenever you're ready."
  structuredData={structuredData}
  noindex={true}
>
  <section class="max-w-2xl mx-auto px-5 md:px-8 py-20 md:py-28 text-center">
    <div class="text-5xl mb-4" aria-hidden="true">🕯️</div>
    <h1 class="font-display text-4xl md:text-5xl tracking-tight mb-4">No worries — your cart is still waiting.</h1>
    <p class="text-[#3a322f] text-lg leading-relaxed mb-8">
      Looks like checkout was cancelled. Your cart is saved exactly as you left it — jump back in whenever you're ready. If something went wrong or you have a question before ordering, we'd love to <a href="/contact" class="underline underline-offset-4 text-[#8a4b2a]">hear from you</a>.
    </p>
    <div class="flex flex-wrap justify-center gap-3">
      <a href="/cart" class="inline-flex items-center gap-2 rounded-full bg-[#1a1413] text-[#f6efe6] px-6 py-3 font-medium hover:bg-[#8a4b2a] transition">Back to cart →</a>
      <a href="/shop" class="inline-flex items-center gap-2 rounded-full border border-[#1a1413]/30 px-6 py-3 font-medium hover:bg-[#1a1413] hover:text-[#f6efe6] transition">Keep shopping</a>
    </div>
  </section>
</Base>
