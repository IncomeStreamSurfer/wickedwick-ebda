---
import Base from '../layouts/Base.astro';
const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://wickedwick-ebda.vercel.app';

const faqs = [
  { q: 'How long do Wicked Wick Co. candles burn?', a: 'Our 8 oz candles burn for 45–55 hours depending on scent, and our 10 oz Smoky Oud burns for 60 hours. Burn time depends heavily on how you burn — trim the wick and burn in full 2-3 hour sessions to get the longest life out of every candle.' },
  { q: 'What kind of wax do you use?', a: 'We use 100% American-grown, GMO-free soy wax in every candle. No paraffin, no wax blends. Soy burns cooler, lasts longer, and produces far less soot than paraffin. It\'s also renewable and biodegradable.' },
  { q: 'Are your candles clean-burning? Are they safe for pets?', a: 'Yes. We use phthalate-free fragrance oils, lead-free cotton wicks, and pure soy. That said, no open flame is completely pet-safe — burn candles in well-ventilated rooms, keep them away from fabric, and never leave them unattended or near pets who might knock them over.' },
  { q: 'How do I get the longest burn time?', a: 'Three rules. (1) On the very first burn, let the wax melt edge-to-edge of the glass — this sets your "memory pool" and prevents tunneling. (2) Trim the cotton wick to ¼ inch before every light. (3) Don\'t burn for more than 4 hours at a time. Follow all three and an 8 oz candle comfortably hits 50 hours.' },
  { q: 'Why is my candle "tunneling" down the middle?', a: 'Tunneling usually happens when the first burn is too short. Candles have a "memory" — if you blow it out before the melt pool reaches the edges, it\'ll only burn that diameter forever. Fix it by burning on low heat with foil wrapped around the top to force an even melt pool.' },
  { q: 'Do you offer free shipping?', a: 'Yes — free shipping automatically on all US orders over $50. Under $50 it\'s a flat $6. Full details on our shipping and returns page.' },
  { q: 'Where do you ship?', a: 'We currently ship to the US, Canada, UK, EU, and Australia. Orders usually arrive in 2–5 business days domestically and 7–14 days internationally. International customers are responsible for any import duties.' },
  { q: 'What\'s your return policy?', a: 'We stand behind every candle with a 30-day burn guarantee. If something arrives damaged or isn\'t right, email us within 30 days and we\'ll refund or replace. See our shipping and returns page for details on how to start a return.' },
  { q: 'Are the candles gift-ready?', a: 'Yes. Every candle ships in our signature matte-black gift box with a handwritten card. You can add a gift note in the cart before checkout — we\'ll hand-letter it in the studio.' },
  { q: 'Do you make custom or wholesale candles?', a: 'We do limited custom-scent work for weddings and events, plus small wholesale runs for hotels and boutiques. Email us through our contact form and we\'ll send over the lookbook.' },
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
      { '@type': 'ListItem', position: 2, name: 'FAQ', item: `${siteUrl}/faq` },
    ],
  },
];
---
<Base
  title="Candle Care FAQ | Wicked Wick Co."
  description="Got questions? Find answers about burn time, soy wax, ingredients, shipping, and returns for all Wicked Wick Co. candles."
  structuredData={structuredData}
>
  <section class="max-w-3xl mx-auto px-5 md:px-8 pt-12 md:pt-16 pb-20">
    <nav class="text-xs text-[#3a322f]/70 mb-4" aria-label="Breadcrumb">
      <a href="/" class="hover:text-[#8a4b2a]">Home</a>
      <span class="mx-2">/</span>
      <span>FAQ</span>
    </nav>
    <p class="text-xs uppercase tracking-[0.3em] text-[#8a4b2a] mb-3">Questions, answered</p>
    <h1 class="font-display text-4xl md:text-5xl tracking-tight leading-tight mb-5">Candle FAQs — everything you need to know.</h1>
    <p class="text-lg text-[#3a322f] max-w-2xl mb-10">
      Quick answers to the questions we get most about candle care, soy candles, burn time, shipping, and returns. Still stuck? Our <a href="/contact" class="underline underline-offset-4 text-[#8a4b2a]">contact form</a> goes straight to the studio.
    </p>

    <div class="space-y-3">
      {faqs.map((f, i) => (
        <details class="group rounded-2xl bg-white/70 border border-[#e5d9c5] open:bg-white transition-all">
          <summary class="cursor-pointer list-none px-5 py-4 flex items-center justify-between gap-4">
            <span class="font-display text-lg text-[#1a1413]">{f.q}</span>
            <span class="text-xl transition-transform group-open:rotate-45" aria-hidden="true">+</span>
          </summary>
          <div class="px-5 pb-5 text-[#3a322f] leading-relaxed">{f.a}</div>
        </details>
      ))}
    </div>

    <div class="mt-14 rounded-3xl bg-[#1a1413] text-[#f6efe6] p-8 text-center">
      <h2 class="font-display text-2xl md:text-3xl tracking-tight mb-3">Still have a question?</h2>
      <p class="text-[#e5d9c5]/90 mb-6">
        Check our <a href="/shipping-returns" class="underline underline-offset-4 text-[#c08457]">shipping &amp; returns policy</a>, browse <a href="/shop" class="underline underline-offset-4 text-[#c08457]">the full collection</a>, or drop us a line.
      </p>
      <a href="/contact" class="inline-flex items-center gap-2 rounded-full bg-[#c08457] text-[#1a1413] px-6 py-3 font-medium hover:bg-[#f6efe6] transition">Contact us →</a>
    </div>
  </section>
</Base>
