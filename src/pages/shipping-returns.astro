---
import Base from '../layouts/Base.astro';
const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://wickedwick-ebda.vercel.app';
const structuredData = [{
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Shipping & Returns', item: `${siteUrl}/shipping-returns` },
  ],
}];
---
<Base
  title="Shipping & Returns | Wicked Wick Co."
  description="Free shipping on orders over $50. Learn about Wicked Wick Co. shipping timelines, carriers, and our simple returns policy."
  structuredData={structuredData}
>
  <section class="max-w-3xl mx-auto px-5 md:px-8 pt-12 md:pt-16 pb-20">
    <nav class="text-xs text-[#3a322f]/70 mb-4" aria-label="Breadcrumb">
      <a href="/" class="hover:text-[#8a4b2a]">Home</a>
      <span class="mx-2">/</span>
      <span>Shipping &amp; Returns</span>
    </nav>
    <p class="text-xs uppercase tracking-[0.3em] text-[#8a4b2a] mb-3">The policies</p>
    <h1 class="font-display text-4xl md:text-5xl tracking-tight leading-tight mb-5">Shipping &amp; Returns</h1>
    <p class="text-lg text-[#3a322f] leading-relaxed max-w-2xl mb-10">
      Our candle shipping and returns policy is short, human, and in your favor. Here's exactly how it works.
    </p>

    <h2 class="font-display text-2xl md:text-3xl tracking-tight mb-4">Shipping</h2>

    <div class="rounded-2xl bg-white/70 border border-[#e5d9c5] p-6 mb-6">
      <h3 class="font-display text-xl mb-3">Processing time</h3>
      <p class="text-[#3a322f] leading-relaxed">
        Every candle is hand-poured to order, so we take up to <strong>2 business days</strong> to pack and dispatch your order. We ship Monday through Friday.
      </p>
    </div>

    <div class="rounded-2xl bg-white/70 border border-[#e5d9c5] p-6 mb-6">
      <h3 class="font-display text-xl mb-3">Rates &amp; transit time</h3>
      <ul class="space-y-2 text-[#3a322f]">
        <li class="flex justify-between gap-4 py-2 border-b border-[#e5d9c5]"><span>US — Standard (USPS, 2-5 business days)</span><span>$6 flat / <strong class="text-[#8a4b2a]">FREE over $50</strong></span></li>
        <li class="flex justify-between gap-4 py-2 border-b border-[#e5d9c5]"><span>Canada</span><span>$14 (5-10 business days)</span></li>
        <li class="flex justify-between gap-4 py-2 border-b border-[#e5d9c5]"><span>UK &amp; EU</span><span>$18 (7-14 business days)</span></li>
        <li class="flex justify-between gap-4 py-2"><span>Australia</span><span>$22 (10-16 business days)</span></li>
      </ul>
      <p class="text-sm text-[#3a322f]/70 mt-3">International customers are responsible for any import duties or taxes charged at delivery.</p>
    </div>

    <div class="rounded-2xl bg-white/70 border border-[#e5d9c5] p-6 mb-10">
      <h3 class="font-display text-xl mb-3">Tracking</h3>
      <p class="text-[#3a322f] leading-relaxed">
        You'll get a tracking number by email as soon as your candles leave the workshop. If it's been more than 2 business days since your order and you haven't received a shipping notification, <a href="/contact" class="underline underline-offset-4 text-[#8a4b2a]">let us know</a> — we'll look into it the same day.
      </p>
    </div>

    <h2 class="font-display text-2xl md:text-3xl tracking-tight mb-4">Returns</h2>

    <div class="rounded-2xl bg-white/70 border border-[#e5d9c5] p-6 mb-6">
      <h3 class="font-display text-xl mb-3">Our 30-day burn guarantee</h3>
      <p class="text-[#3a322f] leading-relaxed mb-3">
        Light your candle. Live with it. If you aren't happy — for any reason at all — email us within <strong>30 days of delivery</strong> and we'll make it right. That means either a full refund or a replacement candle of your choice, on us.
      </p>
      <p class="text-[#3a322f] leading-relaxed">
        You don't have to ship the candle back. You don't have to fill out a form. Just tell us what went wrong, and we'll take it from there.
      </p>
    </div>

    <div class="rounded-2xl bg-white/70 border border-[#e5d9c5] p-6 mb-6">
      <h3 class="font-display text-xl mb-3">Damaged in transit</h3>
      <p class="text-[#3a322f] leading-relaxed">
        Glass happens, even with our obsessive packaging. If your candle arrives broken, send us a photo within 7 days and we'll ship a replacement immediately — no need to return the damaged candle.
      </p>
    </div>

    <div class="rounded-2xl bg-white/70 border border-[#e5d9c5] p-6 mb-10">
      <h3 class="font-display text-xl mb-3">How to start a return</h3>
      <p class="text-[#3a322f] leading-relaxed">
        Use our <a href="/contact" class="underline underline-offset-4 text-[#8a4b2a]">contact form</a> or reply to your order confirmation email. Include your order number (starts with "WW-") and a quick note about what's going on. We process returns same-day during business hours.
      </p>
    </div>

    <div class="rounded-3xl bg-[#1a1413] text-[#f6efe6] p-8 text-center">
      <h2 class="font-display text-2xl md:text-3xl tracking-tight mb-3">Any other questions?</h2>
      <p class="text-[#e5d9c5]/90 mb-6">
        Check our <a href="/faq" class="underline underline-offset-4 text-[#c08457]">FAQ</a> or browse <a href="/shop" class="underline underline-offset-4 text-[#c08457]">the collection</a>.
      </p>
      <a href="/contact" class="inline-flex items-center gap-2 rounded-full bg-[#c08457] text-[#1a1413] px-6 py-3 font-medium hover:bg-[#f6efe6] transition">Contact us →</a>
    </div>
  </section>
</Base>
