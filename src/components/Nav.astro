---
const { pathname } = Astro.url;
const isActive = (href: string) => pathname === href || (href !== '/' && pathname.startsWith(href));
---
<header class="sticky top-0 z-40 border-b border-[#e5d9c5] bg-[#f6efe6]/85 backdrop-blur">
  <nav class="max-w-6xl mx-auto px-5 md:px-8 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 font-display text-xl tracking-tight">
      <span class="text-2xl wick-flicker" aria-hidden="true">🕯️</span>
      <span>Wicked Wick Co.</span>
    </a>
    <ul class="hidden md:flex items-center gap-8 text-sm font-medium">
      <li><a href="/shop" class={`hover:text-[#8a4b2a] ${isActive('/shop') ? 'text-[#8a4b2a]' : ''}`}>Shop</a></li>
      <li><a href="/about" class={`hover:text-[#8a4b2a] ${isActive('/about') ? 'text-[#8a4b2a]' : ''}`}>About</a></li>
      <li><a href="/blog" class={`hover:text-[#8a4b2a] ${isActive('/blog') ? 'text-[#8a4b2a]' : ''}`}>Blog</a></li>
      <li><a href="/faq" class={`hover:text-[#8a4b2a] ${isActive('/faq') ? 'text-[#8a4b2a]' : ''}`}>FAQ</a></li>
      <li><a href="/contact" class={`hover:text-[#8a4b2a] ${isActive('/contact') ? 'text-[#8a4b2a]' : ''}`}>Contact</a></li>
    </ul>
    <a href="/cart" class="relative inline-flex items-center gap-2 rounded-full bg-[#1a1413] text-[#f6efe6] px-4 py-2 text-sm font-medium hover:bg-[#8a4b2a] transition">
      <span aria-hidden="true">🛒</span>
      <span>Cart</span>
      <span id="nav-cart-count" class="ml-1 rounded-full bg-[#c08457] text-[#1a1413] text-xs font-semibold px-2 py-0.5 hidden">0</span>
    </a>
  </nav>
</header>
<script is:inline>
  (function() {
    function refreshCartCount() {
      try {
        const raw = localStorage.getItem('ww_cart');
        const cart = raw ? JSON.parse(raw) : {};
        const count = Object.values(cart).reduce((s, v) => s + (Number(v) || 0), 0);
        const badge = document.getElementById('nav-cart-count');
        if (!badge) return;
        if (count > 0) {
          badge.textContent = String(count);
          badge.classList.remove('hidden');
        } else {
          badge.classList.add('hidden');
        }
      } catch (e) {}
    }
    refreshCartCount();
    window.addEventListener('storage', refreshCartCount);
    window.addEventListener('ww:cart', refreshCartCount);
  })();
</script>
